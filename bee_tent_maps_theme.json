{
  "_comment": "Bee Tent Maps redesign theme for customtkinter. Use with: ctk.set_default_color_theme('bee_tent_maps_theme.json') and ctk.set_appearance_mode('light'). Each color is [light, dark]; both set to the light-shell value so appearance stays consistent. Corner radius + fonts match the design system.",

  "CTk": { "fg_color": ["#F4F1EA", "#F4F1EA"] },
  "CTkToplevel": { "fg_color": ["#F4F1EA", "#F4F1EA"] },

  "CTkFrame": {
    "corner_radius": 12,
    "border_width": 1,
    "fg_color": ["#FFFFFF", "#FFFFFF"],
    "top_fg_color": ["#FBF9F5", "#FBF9F5"],
    "border_color": ["#E4DFD4", "#E4DFD4"]
  },

  "CTkButton": {
    "corner_radius": 9,
    "border_width": 0,
    "fg_color": ["#B87514", "#B87514"],
    "hover_color": ["#9E6410", "#9E6410"],
    "border_color": ["#B87514", "#B87514"],
    "text_color": ["#FFFFFF", "#FFFFFF"],
    "text_color_disabled": ["#C9C2B4", "#C9C2B4"]
  },

  "CTkLabel": {
    "corner_radius": 0,
    "fg_color": "transparent",
    "text_color": ["#221F1A", "#221F1A"]
  },

  "CTkEntry": {
    "corner_radius": 9,
    "border_width": 1,
    "fg_color": ["#FFFFFF", "#FFFFFF"],
    "border_color": ["#D8D2C4", "#D8D2C4"],
    "text_color": ["#221F1A", "#221F1A"],
    "placeholder_text_color": ["#938C7E", "#938C7E"]
  },

  "CTkCheckBox": {
    "corner_radius": 6,
    "border_width": 2,
    "fg_color": ["#B87514", "#B87514"],
    "border_color": ["#CFC8BA", "#CFC8BA"],
    "hover_color": ["#9E6410", "#9E6410"],
    "checkmark_color": ["#FFFFFF", "#FFFFFF"],
    "text_color": ["#3A352C", "#3A352C"],
    "text_color_disabled": ["#B4AD9E", "#B4AD9E"]
  },

  "CTkSwitch": {
    "corner_radius": 1000,
    "border_width": 3,
    "button_length": 0,
    "fg_color": ["#E4DFD4", "#E4DFD4"],
    "progress_color": ["#B87514", "#B87514"],
    "button_color": ["#FFFFFF", "#FFFFFF"],
    "button_hover_color": ["#F4F1EA", "#F4F1EA"],
    "text_color": ["#3A352C", "#3A352C"],
    "text_color_disabled": ["#B4AD9E", "#B4AD9E"]
  },

  "CTkOptionMenu": {
    "corner_radius": 9,
    "fg_color": ["#FFFFFF", "#FFFFFF"],
    "button_color": ["#EDE8DE", "#EDE8DE"],
    "button_hover_color": ["#E1DACC", "#E1DACC"],
    "text_color": ["#221F1A", "#221F1A"],
    "text_color_disabled": ["#B4AD9E", "#B4AD9E"]
  },

  "CTkComboBox": {
    "corner_radius": 9,
    "border_width": 1,
    "fg_color": ["#FFFFFF", "#FFFFFF"],
    "border_color": ["#D8D2C4", "#D8D2C4"],
    "button_color": ["#EDE8DE", "#EDE8DE"],
    "button_hover_color": ["#E1DACC", "#E1DACC"],
    "text_color": ["#221F1A", "#221F1A"],
    "text_color_disabled": ["#B4AD9E", "#B4AD9E"]
  },

  "CTkScrollbar": {
    "corner_radius": 1000,
    "border_spacing": 3,
    "fg_color": "transparent",
    "button_color": ["#CFC9BC", "#CFC9BC"],
    "button_hover_color": ["#B8B1A1", "#B8B1A1"]
  },

  "CTkSegmentedButton": {
    "corner_radius": 8,
    "border_width": 3,
    "fg_color": ["#F0ECE3", "#F0ECE3"],
    "selected_color": ["#B87514", "#B87514"],
    "selected_hover_color": ["#9E6410", "#9E6410"],
    "unselected_color": ["#F0ECE3", "#F0ECE3"],
    "unselected_hover_color": ["#E7E1D6", "#E7E1D6"],
    "text_color": ["#FFFFFF", "#FFFFFF"],
    "text_color_disabled": ["#B4AD9E", "#B4AD9E"]
  },

  "CTkProgressBar": {
    "corner_radius": 1000,
    "border_width": 0,
    "fg_color": ["#F0ECE3", "#F0ECE3"],
    "progress_color": ["#34C97B", "#34C97B"],
    "border_color": ["#E4DFD4", "#E4DFD4"]
  },

  "CTkTextbox": {
    "corner_radius": 9,
    "border_width": 1,
    "fg_color": ["#FFFFFF", "#FFFFFF"],
    "border_color": ["#D8D2C4", "#D8D2C4"],
    "text_color": ["#221F1A", "#221F1A"],
    "scrollbar_button_color": ["#CFC9BC", "#CFC9BC"],
    "scrollbar_button_hover_color": ["#B8B1A1", "#B8B1A1"]
  },

  "CTkFont": {
    "macOS":   { "family": "Helvetica Neue", "size": 14, "weight": "normal" },
    "Windows": { "family": "Segoe UI",       "size": 14, "weight": "normal" },
    "Linux":   { "family": "Roboto",         "size": 14, "weight": "normal" }
  }
}
