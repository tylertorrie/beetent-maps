# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.swp
*.swo

# Virtual environments
.venv/
venv/
env/

# Nuitka build output
beetent_trimble/
*.dist/
*.build/
*.onefile-build/
nuitka-crash-report.xml

# Editor / OS
.DS_Store
Thumbs.db
*.bak
*.tmp

# Claude Code worktrees and session data (keep CLAUDE.md + shared settings.json)
.claude/worktrees/
.claude/projects/
.claude/todos/
.claude/settings.local.json

# Tile cache (local SQLite, can be large)
*.db

# Sensitive / large data files
*.csv
*.ods
*.xlsx

# PDF map image cache (device-local, not synced — regenerated on first PDF export)
fields/**/*_map.jpg
fields/**/*_map.json

# Output library for the in-app Files view — DO track it (synced across devices,
# like fields/). Holds generated export bundles + summary PDFs + index.json.
# (The broad *.csv/*.db/*.xlsx ignores above don't match its shp/kml/zip/geojson/pdf.)
!output/

# Compiled/installed dependencies that ship with the source
# (shapefile.py, simplekml, utm, fpdf are vendored — DO track them)
