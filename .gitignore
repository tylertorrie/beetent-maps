# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.swp
*.swo

# Virtual environments
.venv/
venv/
env/

# Nuitka build output
beetent_trimble/
*.dist/
*.build/
*.onefile-build/
nuitka-crash-report.xml

# Editor / OS
.DS_Store
Thumbs.db
*.bak
*.tmp

# Claude Code worktrees and session data (keep CLAUDE.md + shared settings.json)
.claude/worktrees/
.claude/projects/
.claude/todos/
.claude/settings.local.json

# Tile cache (local SQLite, can be large) — device-local, never synced
*.db
*.db-wal
*.db-shm

# Sensitive / large data files
*.csv
*.ods
*.xlsx

# PDF map image cache (device-local, not synced — regenerated on first PDF export)
fields/**/*_map.jpg
fields/**/*_map.json

# Output library for the in-app Files view — DO track it (synced across devices,
# like fields/). Holds generated export bundles + summary PDFs + index.json.
# (The broad *.csv/*.db/*.xlsx ignores above don't match its shp/kml/zip/geojson/pdf.)
!output/

# Reference Files library (in-app Files view → Reference tab). DO track every
# file type here — checklists/guides/spreadsheets etc. must sync across devices,
# so these negations override the broad *.csv/*.xlsx/*.ods ignores above.
!reference/
!reference/**

# Firebase relay config — contains the shared auth token, NEVER commit (repo is
# public). Each device fills its own copy from the *.example templates.
firebase_config.json
tablet/firebase-config.js

# Google Maps API key for Cost Estimator travel times — secret, repo is public.
maps_api_key.txt

# Supabase credentials — service_role key must NEVER be committed (repo is public).
supabase_config.json
.env
**/.env
.env.local
**/.env.local

# Compiled/installed dependencies that ship with the source
# (shapefile.py, simplekml, utm, fpdf are vendored — DO track them)

# Transient test/run logs
_err.log
_out.log
.pytest_cache/

# Device-local UI state (collapsed insets, recents, active layer)
fields/ui_prefs.json
